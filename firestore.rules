rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function challengeParticipantIds() {
      return resource.data.participantIds;
    }

    function requestChallengeParticipantIds() {
      return request.resource.data.participantIds;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /territories/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;

      match /gps_points/{pointId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /friend_challenges/{challengeId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.hostUserId == request.auth.uid
        && request.auth.uid in requestChallengeParticipantIds();

      allow update: if isSignedIn()
        && request.auth.uid in challengeParticipantIds();

      allow delete: if false;
    }
  }
}
